# Streamlit Community Cloud: Settings → Secrets (valid TOML).
# A raw shell .env is NOT valid TOML unless you wrap it (see DOTENV below).

# --- Option A (recommended): top-level keys ---
TRF_API_BASE_URL = "https://your-fastapi-host.example.com"
TRF_UI_USERNAME = "admin"
TRF_UI_PASSWORD = "same-as-backend-basic-auth"

# OPENAI_API_KEY is only needed in the FastAPI deployment, not in Streamlit,
# unless you call OpenAI from this app.

# --- Option B: paste your whole .env as a multiline string ---
# DOTENV = """
# TRF_API_BASE_URL=https://your-fastapi-host.example.com
# TRF_UI_USERNAME=admin
# TRF_UI_PASSWORD=changeme
# OPENAI_API_KEY=sk-...
# """

# --- Option C: TOML table (nested keys) ---
# [env]
# TRF_API_BASE_URL = "https://your-fastapi-host.example.com"
